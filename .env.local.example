# 이 파일은 견본입니다. 실제 값은 .env.local 에 넣으세요 (.env.local은 git에 안 올라감)

# MongoDB 연결 문자열
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=videogen

# Claude (스토리보드 → Veo3 프롬프트 생성) — Phase 2에서 사용
ANTHROPIC_API_KEY=

# Google Gemini (Veo 3 렌더링) — Phase 4에서 사용
GEMINI_API_KEY=
