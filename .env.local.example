# 이 파일은 견본입니다. 실제 값은 .env.local 에 넣으세요 (.env.local은 git에 안 올라감)

# MongoDB 연결 문자열
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=videogen

# Claude (스토리보드 → Veo3 프롬프트 생성) — Phase 2에서 사용
ANTHROPIC_API_KEY=

# Google Gemini (Veo 3 렌더링) — Phase 4에서 사용
GEMINI_API_KEY=
# (선택) Veo 렌더 옵션
GEMINI_VEO_MODEL=veo-3.1-fast-generate-preview
GEMINI_VEO_DURATION=4
GEMINI_VEO_RESOLUTION=720p

# Cafe24 FTP — 이미지·렌더 영상 저장 (Phase: FTP 스토리지)
YOGIBO_FTP=yogibo.ftp.cafe24.com
YOGIBO_FTP_ID=
YOGIBO_FTP_PW=
FTP_PUBLIC_BASE=https://yogibo.openhost.cafe24.com/
FTP_REMOTE_DIR=web/img/ai

# Higgsfield (역동적 모션 영상 엔진) — 인증: Key <KEY_ID>:<KEY_SECRET>
HIGGSFIELD_KEY_ID=
HIGGSFIELD_KEY_SECRET=
# (선택) 모델 등급 — 비용: dop-lite < dop-turbo < dop-standard (기본 최저가)
HIGGSFIELD_MODEL=dop-lite
